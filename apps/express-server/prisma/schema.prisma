datasource db {
  provider = "postgresql"
  url      = env("NX_PSQL_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id
  email     String   @unique
  password  String
  username  String
  // role      Role?    @default(USER)
  createdAt DateTime @default(now())
}

model Test {
  id        String   @id
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  USER
  ADMIN
}
