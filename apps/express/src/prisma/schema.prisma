generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("NX_PSQL_URL")
}

model User {
  id               String         @id
  email            String         @unique
  password         String         @default("IT_IS_SSO_USER")
  createdAt        DateTime       @default(now())
  ssoSub           String         @default("IT_IS_KURAKICHI_ORIGINAL_USER")
  picture          String         @default("UNKNOWN")
  name             String
  role             USER_ROLE      @default(USER)
  receivedMessages Message[]      @relation("receive")
  sentMessages     Message[]      @relation("sent")
  manageOrg        Organization[] @relation("orgAdmin")
  manageRoom       SecureBase[]   @relation("baseAdmin")
  belongRooms      SecureBase[]   @relation("baseMember")
  belongOrgs       Organization[] @relation("orgMember")
  requestJoinOrgs  Organization[] @relation("requestedMember")
  sentInquiry      Inquiry[]      @relation("inquiry")
}

model Organization {
  id               String    @id
  name             String    @unique
  adminId          String
  location         String    @default("UNKNOWN")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  phone            String    @default("UNKNOWN")
  email            String    @default("UNKNOWN")
  description      String    @default("UNKNOWN")
  homePage         String    @default("UNKNOWN")
  image            String    @default("UNKNOWN")
  icon             String    @default("UNKNOWN")
  admin            User      @relation("orgAdmin", fields: [adminId], references: [id])
  members          User[]    @relation("orgMember")
  requestedMembers User[]    @relation("requestedMember")
  inquiries        Inquiry[] @relation("gotInquiry")
}

model Message {
  id         String   @id
  text       String
  senderId   String
  receiverId String
  read_flag  Boolean  @default(false)
  createdAt  DateTime @default(now())
  send_flag  Boolean  @default(false)
  receiver   User     @relation("receive", fields: [receiverId], references: [id])
  sender     User     @relation("sent", fields: [senderId], references: [id])
}

model Inquiry {
  id         String           @id
  text       String
  senderId   String
  receiverId String
  createdAt  DateTime         @default(now())
  category   INQUIRY_CATEGORY @default(COUNSEL)
  status     INQUIRY_STATUS   @default(UNREAD)
  send_flag  Boolean          @default(false)
  sender     User             @relation("inquiry", fields: [senderId], references: [id])
  receiver   Organization     @relation("gotInquiry", fields: [receiverId], references: [id])
}

model Dialog {
  id   String @id
  text String
}

model SecureBase {
  id      String @id
  adminId String
  admin   User   @relation("baseAdmin", fields: [adminId], references: [id])
  karte   Karte?
  members User[] @relation("baseMember")
}

model Karte {
  id     String     @id
  record String
  baseId String
  base   SecureBase @relation(fields: [baseId], references: [id])
}

enum USER_ROLE {
  USER
  PRO
}

enum INQUIRY_CATEGORY {
  COUNSEL
  INQUIRY
  CONTACT
  APPLICATION
  OTHERS
}

enum INQUIRY_STATUS {
  UNREAD
  WORKING
  DONE
}
