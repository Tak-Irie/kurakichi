datasource db {
  provider = "postgresql"
  url      = env("NX_PSQL_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id         String         @id
  email      String         @unique
  name       String
  password   String         @default("IT_IS_SSO_USER")
  ssoSub     String         @default("IT_IS_KURAKICHI_ORIGINAL_USER")
  picture    String         @default("UNKNOWN")
  rooms      Room[]
  orgs       Organization[]
  createdAt  DateTime       @default(now())
  manageOrg  Organization[] @relation("orgAdmin")
  manageRoom Room[]         @relation("roomAdmin")
}

model Organization {
  id        String   @id
  name      String   @unique
  admin     User     @relation("orgAdmin", fields: [adminId], references: [id])
  adminId   String
  members   User[]
  location  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Dialog {
  id   String @id
  text String
}

model Room {
  id      String @id
  admin   User   @relation("roomAdmin", fields: [adminId], references: [id])
  adminId String
  members User[]
  karte   Karte?
}

model Karte {
  id     String @id
  room   Room   @relation(fields: [roomId], references: [id])
  roomId String
  record String
}

enum Role {
  USER
  ADMIN
}
