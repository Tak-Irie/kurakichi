{
  "version": 2,
  "projects": {
    "next-web": {
      "root": "apps/next-web",
      "sourceRoot": "apps/next-web",
      "projectType": "application",
      "targets": {
        "build": {
          "executor": "@nrwl/next:build",
          "outputs": ["{options.outputPath}"],
          "options": {
            "root": "apps/next-web",
            "outputPath": "dist/apps/next-web"
          },
          "configurations": {
            "production": {}
          }
        },
        "serve": {
          "executor": "@nrwl/next:server",
          "options": {
            "buildTarget": "next-web:build",
            "dev": true
          },
          "configurations": {
            "production": {
              "buildTarget": "next-web:build:production",
              "dev": false
            }
          }
        },
        "export": {
          "executor": "@nrwl/next:export",
          "options": {
            "buildTarget": "next-web:build:production"
          }
        },
        "test": {
          "executor": "@nrwl/jest:jest",
          "outputs": ["coverage/apps/next-web"],
          "options": {
            "jestConfig": "apps/next-web/jest.config.js",
            "passWithNoTests": true
          }
        },
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "options": {
            "lintFilePatterns": ["apps/next-web/**/*.{ts,tsx,js,jsx}"]
          }
        },
        "build-tailwind-css": {
          "executor": "@nrwl/workspace:run-commands",
          "outputs": [],
          "options": {
            "command": "npx tailwindcss-cli@latest build ./src/styles.css -o src/app/tailwind.css",
            "cwd": "apps/next-web"
          }
        }
      }
    },
    "next-web-e2e": {
      "root": "apps/next-web-e2e",
      "sourceRoot": "apps/next-web-e2e/src",
      "projectType": "application",
      "targets": {
        "e2e": {
          "executor": "@nrwl/cypress:cypress",
          "options": {
            "cypressConfig": "apps/next-web-e2e/cypress.json",
            "tsConfig": "apps/next-web-e2e/tsconfig.e2e.json",
            "devServerTarget": "next-web:serve"
          },
          "configurations": {
            "production": {
              "devServerTarget": "next-web:serve:production"
            }
          }
        },
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "options": {
            "lintFilePatterns": ["apps/next-web-e2e/**/*.{js,ts}"]
          }
        }
      }
    },
    "express-server": {
      "root": "apps/express-server",
      "sourceRoot": "apps/express-server/src",
      "projectType": "application",
      "targets": {
        "dev": {
          "executor": "@nrwl/workspace:run-commands",
          "options": {
            "command": "npx nodemon --exec ts-node src/main.ts",
            "cwd": "apps/express-server/"
          }
        },
        "build": {
          "executor": "@nrwl/node:build",
          "outputs": ["{options.outputPath}"],
          "options": {
            "outputPath": "dist/apps/express-server",
            "main": "apps/express-server/src/main.ts",
            "tsConfig": "apps/express-server/tsconfig.app.json"
          },
          "configurations": {
            "production": {
              "optimization": true,
              "extractLicenses": true,
              "inspect": false,
              "fileReplacements": [
                {
                  "replace": "apps/express-server/src/environments/environment.ts",
                  "with": "apps/express-server/src/environments/environment.prod.ts"
                }
              ]
            }
          }
        },
        "serve": {
          "executor": "@nrwl/node:execute",
          "options": {
            "buildTarget": "express-server:build"
          }
        },
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "options": {
            "lintFilePatterns": ["apps/express-server/**/*.ts"]
          }
        },
        "test": {
          "executor": "@nrwl/jest:jest",
          "outputs": ["coverage/apps/express-server"],
          "options": {
            "jestConfig": "apps/express-server/jest.config.js",
            "passWithNoTests": true
          }
        }
      }
    },
    "ddd-modules": {
      "root": "libs/ddd-modules",
      "sourceRoot": "libs/ddd-modules/src",
      "projectType": "library",
      "targets": {
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "options": {
            "lintFilePatterns": ["libs/ddd-modules/**/*.ts"]
          }
        },
        "test": {
          "executor": "@nrwl/jest:jest",
          "outputs": ["coverage/libs/ddd-modules"],
          "options": {
            "jestConfig": "libs/ddd-modules/jest.config.js",
            "passWithNoTests": true
          }
        }
      }
    }
  }
}
