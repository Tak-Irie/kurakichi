{
  "version": 2,
  "cli": {
    "defaultCollection": "@nrwl/express"
  },
  "defaultProject": "express",
  "generators": {
    "@nrwl/react": {
      "application": {
        "babel": true
      }
    },
    "@nrwl/next": {
      "application": {
        "style": "css",
        "linter": "eslint"
      }
    }
  },
  "projects": {
    "express": {
      "root": "apps/express",
      "sourceRoot": "apps/express/src",
      "projectType": "application",
      "prefix": "express",
      "targets": {
        "build": {
          "executor": "@nrwl/node:build",
          "outputs": ["{options.outputPath}"],
          "options": {
            "outputPath": "dist/apps/express",
            "main": "apps/express/src/main.ts",
            "tsConfig": "apps/express/tsconfig.app.json"
          },
          "configurations": {
            "production": {
              "optimization": true,
              "extractLicenses": true,
              "inspect": false,
              "fileReplacements": [
                {
                  "replace": "apps/express/src/environments/environment.ts",
                  "with": "apps/express/src/environments/environment.prod.ts"
                }
              ]
            }
          }
        },
        "serve": {
          "executor": "@nrwl/node:execute",
          "options": {
            "buildTarget": "express:build"
          }
        },
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "options": {
            "lintFilePatterns": ["apps/express/**/*.ts"]
          }
        },
        "test": {
          "executor": "@nrwl/jest:jest",
          "outputs": ["coverage/apps/express"],
          "options": {
            "jestConfig": "apps/express/jest.config.js",
            "passWithNoTests": true
          }
        }
      }
    },
    "next": {
      "root": "apps/next",
      "sourceRoot": "apps/next",
      "projectType": "application",
      "targets": {
        "build": {
          "executor": "@nrwl/next:build",
          "outputs": ["{options.outputPath}"],
          "options": {
            "root": "apps/next",
            "outputPath": "dist/apps/next"
          },
          "configurations": {
            "production": {}
          }
        },
        "serve": {
          "executor": "@nrwl/next:server",
          "options": {
            "buildTarget": "next:build",
            "dev": true
          },
          "configurations": {
            "production": {
              "buildTarget": "next:build:production",
              "dev": false
            }
          }
        },
        "export": {
          "executor": "@nrwl/next:export",
          "options": {
            "buildTarget": "next:build:production"
          }
        },
        "test": {
          "executor": "@nrwl/jest:jest",
          "outputs": ["coverage/apps/next"],
          "options": {
            "jestConfig": "apps/next/jest.config.js",
            "passWithNoTests": true
          }
        },
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "options": {
            "lintFilePatterns": ["apps/next/**/*.{ts,tsx,js,jsx}"]
          }
        }
      }
    },
    "next-e2e": {
      "root": "apps/next-e2e",
      "sourceRoot": "apps/next-e2e/src",
      "projectType": "application",
      "targets": {
        "e2e": {
          "executor": "@nrwl/cypress:cypress",
          "options": {
            "cypressConfig": "apps/next-e2e/cypress.json",
            "tsConfig": "apps/next-e2e/tsconfig.e2e.json",
            "devServerTarget": "next:serve"
          },
          "configurations": {
            "production": {
              "devServerTarget": "next:serve:production"
            }
          }
        },
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "options": {
            "lintFilePatterns": ["apps/next-e2e/**/*.{js,ts}"]
          }
        }
      }
    },
    "node-util": {
      "root": "libs/node-util",
      "sourceRoot": "libs/node-util/src",
      "projectType": "library",
      "targets": {
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "options": {
            "lintFilePatterns": ["libs/node-util/**/*.ts"]
          }
        },
        "test": {
          "executor": "@nrwl/jest:jest",
          "outputs": ["coverage/libs/node-util"],
          "options": {
            "jestConfig": "libs/node-util/jest.config.js",
            "passWithNoTests": true
          }
        }
      }
    },
    "domain": {
      "root": "libs/domain",
      "sourceRoot": "libs/domain/src",
      "projectType": "library",
      "targets": {
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "options": {
            "lintFilePatterns": ["libs/domain/**/*.ts"]
          }
        },
        "test": {
          "executor": "@nrwl/jest:jest",
          "outputs": ["coverage/libs/domain"],
          "options": {
            "jestConfig": "libs/domain/jest.config.js",
            "passWithNoTests": true
          }
        }
      }
    }
  }
}
